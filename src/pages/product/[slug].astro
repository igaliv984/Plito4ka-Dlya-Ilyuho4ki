---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import InquiryForm from "@/components/InquiryForm.astro";
import ProductCard from "@/components/ProductCard.astro";
import TileCalculator from "@/components/TileCalculator.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbs, getCategoryBySlug, getProductBySlug, getRelatedProducts } from "@/lib/content";
import { getSiteData } from "@/lib/google-sheets";

export async function getStaticPaths() {
  const data = await getSiteData();

  return data.products.map((product) => ({
    params: { slug: product.slug }
  }));
}

const { slug } = Astro.params;
const data = await getSiteData();
const product = await getProductBySlug(slug ?? "");

if (!product) {
  return Astro.redirect("/404/");
}

const category = await getCategoryBySlug(product.category);
const relatedProducts = await getRelatedProducts(product, 3);
const formatter = new Intl.NumberFormat("ru-RU");
const hasPrice = product.priceM2 > 0;

const seo = {
  title: product.seoTitle,
  description: product.seoDescription,
  h1: product.name,
  canonicalPath: `/product/${product.slug}/`,
  image: product.mainImage
};

const breadcrumbItems = buildBreadcrumbs([
  { name: "Каталог", href: "/catalog/" },
  category ? { name: category.name, href: `/catalog/${category.slug}/` } : { name: "Категория", href: "/catalog/" },
  { name: product.name, href: `/product/${product.slug}/` }
]);

const productSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  image: [product.mainImage, ...product.galleryImages],
  description: product.description,
  sku: product.id,
  brand: {
    "@type": "Brand",
    name: product.brand || data.settings.storeName
  }
};

if (hasPrice) {
  productSchema.offers = {
    "@type": "Offer",
    priceCurrency: "RUB",
    price: product.priceM2,
    availability: product.inStock ? "https://schema.org/InStock" : "https://schema.org/PreOrder",
    url: new URL(`/product/${product.slug}/`, Astro.site ?? "https://example-tile-store.netlify.app").toString()
  };
}

const schema = [
  productSchema,
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      item: new URL(item.href, Astro.site ?? "https://example-tile-store.netlify.app").toString()
    }))
  }
];
---

<BaseLayout seo={seo} schema={schema}>
  <section class="container-shell py-10">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="grid gap-10 lg:grid-cols-[1.1fr,0.9fr]">
      <div class="space-y-4">
        <div class="surface-card overflow-hidden">
          <img src={product.mainImage} alt={product.altText} class="h-[520px] w-full object-cover" />
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          {[product.mainImage, ...product.galleryImages].slice(0, 4).map((image) => (
            <div class="surface-card overflow-hidden">
              <img src={image} alt={product.altText} class="h-36 w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>

      <div class="space-y-6">
        <div>
          <span class="section-kicker">{category?.name ?? "Товар"}</span>
          <h1 class="mt-4 text-5xl">{product.name}</h1>
          <p class="mt-4 text-lg leading-8 text-stoneInk/70">{product.description}</p>
        </div>

        <div class="surface-card p-6">
          <div class="flex items-start justify-between gap-5">
            <div>
              <p class="text-sm text-stoneInk/45">Цена</p>
              {hasPrice ? (
                <>
                  <p class="mt-2 text-4xl font-semibold">
                    {formatter.format(product.priceM2)} {data.settings.currency}
                  </p>
                  <p class="text-sm text-stoneInk/45">за м²</p>
                </>
              ) : (
                <>
                  <p class="mt-2 text-4xl font-semibold">По запросу</p>
                  <p class="text-sm text-stoneInk/45">цену уточнит менеджер</p>
                </>
              )}
            </div>
            <div class:list={["rounded-full px-4 py-2 text-sm font-semibold", product.inStock ? "bg-pine/10 text-pine" : "bg-clay/10 text-clay"]}>
              {product.inStock ? "В наличии" : "Под заказ"}
            </div>
          </div>

          <dl class="mt-6 grid gap-4 sm:grid-cols-2">
            <div class="rounded-3xl bg-fog p-4">
              <dt class="text-sm text-stoneInk/45">Коллекция</dt>
              <dd class="mt-2 font-semibold">{product.collection}</dd>
            </div>
            {product.brand && (
              <div class="rounded-3xl bg-fog p-4">
                <dt class="text-sm text-stoneInk/45">Бренд</dt>
                <dd class="mt-2 font-semibold">{product.brand}</dd>
              </div>
            )}
            {product.country && (
              <div class="rounded-3xl bg-fog p-4">
                <dt class="text-sm text-stoneInk/45">Страна</dt>
                <dd class="mt-2 font-semibold">{product.country}</dd>
              </div>
            )}
            <div class="rounded-3xl bg-fog p-4">
              <dt class="text-sm text-stoneInk/45">Формат</dt>
              <dd class="mt-2 font-semibold">{product.sizeLabel || "Уточняйте"}</dd>
            </div>
            <div class="rounded-3xl bg-fog p-4">
              <dt class="text-sm text-stoneInk/45">Поверхность</dt>
              <dd class="mt-2 font-semibold">{product.surface || "Уточняйте"}</dd>
            </div>
            <div class="rounded-3xl bg-fog p-4">
              <dt class="text-sm text-stoneInk/45">Плиток в коробке</dt>
              <dd class="mt-2 font-semibold">{product.piecesPerBox}</dd>
            </div>
            {product.stockTotal !== undefined && (
              <div class="rounded-3xl bg-fog p-4">
                <dt class="text-sm text-stoneInk/45">Остаток</dt>
                <dd class="mt-2 font-semibold">
                  {product.stockTotal > 0 ? `${formatter.format(product.stockTotal)} ${product.unit ?? "м²"}` : "Уточняйте"}
                </dd>
              </div>
            )}
          </dl>

          {product.warehouseStock && Object.keys(product.warehouseStock).length > 0 && (
            <div class="mt-6 rounded-3xl bg-fog p-4">
              <p class="text-sm font-semibold text-stoneInk">Остатки по складам</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {Object.entries(product.warehouseStock).map(([warehouse, amount]) => (
                  <div class="rounded-2xl bg-white px-4 py-3 text-sm text-stoneInk/70">
                    <strong class="block text-stoneInk">{warehouse}</strong>
                    <span>{formatter.format(amount)} {product.unit ?? "м²"}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <a href="#lead-form" class="btn-primary flex-1">Оставить заявку</a>
            <a href={`tel:${data.settings.phone.replace(/[^\d+]/g, "")}`} class="btn-secondary flex-1">Позвонить</a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16">
      <TileCalculator
        product={product}
        settings={data.settings}
        title={`Калькулятор для ${product.name}`}
        description="Значения плитки уже подставлены из карточки товара. Остаётся указать размеры помещения и запас."
      />
    </div>

    <div class="mt-16">
      <InquiryForm settings={data.settings} product={product} title="Запросить расчёт и наличие" />
    </div>

    {relatedProducts.length > 0 && (
      <div class="mt-16">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div>
            <span class="section-kicker">Похожие товары</span>
            <h2 class="mt-4 text-4xl">Ещё варианты в том же сегменте</h2>
          </div>
        </div>
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {relatedProducts.map((item) => <ProductCard product={item} settings={data.settings} />)}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
