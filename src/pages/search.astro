---
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildBreadcrumbs, getSearchItems } from "@/lib/content";
import { getSiteData } from "@/lib/google-sheets";

const data = await getSiteData();
const searchItems = await getSearchItems();

const seo = {
  title: `Поиск по сайту | ${data.settings.storeName}`,
  description: "Поиск по товарам, категориям и информационным страницам сайта.",
  h1: "Поиск по сайту",
  canonicalPath: "/search/"
};
---

<BaseLayout seo={seo}>
  <section class="container-shell py-10">
    <Breadcrumbs items={buildBreadcrumbs([{ name: "Поиск", href: "/search/" }])} />
    <div class="max-w-3xl">
      <span class="section-kicker">Поиск</span>
      <h1 class="mt-4 text-5xl">{seo.h1}</h1>
      <p class="mt-4 text-lg leading-8 text-stoneInk/70">
        Ищите товары, категории и страницы сайта с одного экрана. Поиск работает на клиенте и не требует backend.
      </p>
    </div>

    <div class="mt-10 surface-card p-6 md:p-8" data-search-root>
      <form action="/search/" method="GET" class="grid gap-4 md:grid-cols-[1fr,auto]">
        <input
          type="search"
          name="q"
          class="field"
          placeholder="Например: Италия, BURL WOOD, контакты"
          value=""
          data-search-input
        />
        <button class="btn-primary" type="submit">Найти</button>
      </form>

      <p class="mt-5 text-sm text-stoneInk/55">
        Найдено <span class="font-semibold text-stoneInk" data-search-count>{searchItems.length}</span> результатов
      </p>

      <div class="mt-6 grid gap-4" data-search-results>
        {
          searchItems.map((item) => (
            <a
              href={item.href}
              class="surface-card block p-5"
              data-search-item
              data-search-title={item.title.toLowerCase()}
              data-search-description={item.description.toLowerCase()}
              data-search-keywords={item.keywords.join(" ").toLowerCase()}
            >
              <div class="flex flex-wrap items-center gap-3">
                <span class="rounded-full bg-sand-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-sand-800">
                  {item.type === "product" ? "Товар" : item.type === "category" ? "Категория" : "Страница"}
                </span>
                <span class="text-sm text-stoneInk/45">{item.href}</span>
              </div>
              <h2 class="mt-3 text-2xl">{item.title}</h2>
              <p class="mt-2 text-sm leading-7 text-stoneInk/68">{item.description}</p>
            </a>
          ))
        }
      </div>

      <div class="mt-6 hidden rounded-[1.5rem] border border-dashed border-stoneInk/15 p-8 text-center text-stoneInk/55" data-search-empty>
        Ничего не найдено. Попробуй бренд, коллекцию, страну или название страницы.
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const query = new URLSearchParams(window.location.search).get("q")?.trim().toLowerCase() ?? "";
  document.querySelectorAll("[data-search-root]").forEach((root) => {
    const input = root.querySelector("[data-search-input]");
    const items = Array.from(root.querySelectorAll("[data-search-item]"));
    const empty = root.querySelector("[data-search-empty]");
    const count = root.querySelector("[data-search-count]");

    if (input) {
      input.value = query;
    }

    const applyFilter = (value) => {
      const normalized = value.trim().toLowerCase();
      let visible = 0;

      items.forEach((item) => {
        const haystack = [
          item.dataset.searchTitle ?? "",
          item.dataset.searchDescription ?? "",
          item.dataset.searchKeywords ?? ""
        ].join(" ");
        const isMatch = !normalized || haystack.includes(normalized);
        item.classList.toggle("hidden", !isMatch);
        if (isMatch) {
          visible += 1;
        }
      });

      count.textContent = String(visible);
      empty.classList.toggle("hidden", visible > 0);
    };

    applyFilter(query);
  });
</script>
