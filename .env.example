PUBLIC_SITE_URL=https://example-tile-store.netlify.app

# Optional Google Sheets source for products.
# If data/catalog.xlsx exists, it is used first.
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_PRODUCTS_GID=

# Optional extra content sheets.
GOOGLE_SHEETS_PAGES_GID=
GOOGLE_SHEETS_FAQ_GID=
GOOGLE_SHEETS_SEO_GID=
GOOGLE_SHEETS_SETTINGS_GID=

# Local XLSX source for the catalog.
LOCAL_XLSX_PATH=data/catalog.xlsx
